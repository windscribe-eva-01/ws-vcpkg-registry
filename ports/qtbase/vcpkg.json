{
  "name": "qtbase",
  "version": "6.11.0",
  "description": "Qt Base (Core, Gui, Widgets, Network, ...)",
  "homepage": "https://www.qt.io/",
  "license": null,
  "supports": "!uwp",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    {
      "name": "qtbase",
      "host": true,
      "default-features": false
    }
  ],
  "default-features": [
    "gui",
    "network",
    "opengl",
    "widgets",
    "png"
  ],

  "features": {
    "concurrent": {
      "description": "Qt Concurrent"
    },
    "dbus": {
      "description": "Qt D-Bus"
    },
    "gui": {
      "description": "Qt Gui"
    },
    "network": {
      "description": "Qt Network"
    },
    "opengl": {
      "description": "OpenGL support"
    },
    "png": {
      "description": "Enable PNG"
    },
    "testlib": {
      "description": "Qt Test"
    },
    "wayland": {
      "description": "Wayland platform support"
    },
    "widgets": {
      "description": "Qt Widgets"
    }
  }
}
